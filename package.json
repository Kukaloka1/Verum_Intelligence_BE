{
  "name": "verum_be",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --target node22 --out-dir dist --clean",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "ingest:demo-corpus": "tsx src/jobs/poll-official-sources.ts",
    "smoke:embedding-dimension": "tsx src/jobs/smoke-embedding-dimension.ts",
    "smoke:module1-query": "QUERY_GUARDRAILS_MODE=enabled tsx src/jobs/smoke-module1-query.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/sensible": "^6.0.3",
    "@supabase/supabase-js": "^2.49.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.3.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
